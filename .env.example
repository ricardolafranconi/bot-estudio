# ─── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── WhatsApp Cloud API (Meta) ────────────────────────────────────────────────
# ID del número de teléfono registrado en Meta for Developers
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# Token de acceso permanente (o temporal para pruebas)
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxx

# Token personalizado para verificar el webhook (lo inventás vos)
WHATSAPP_VERIFY_TOKEN=mi_token_secreto_1234

# ─── Base de datos ────────────────────────────────────────────────────────────
# Railway provee esta variable automáticamente al agregar el plugin de PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/bot_estudio

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3000

# ─── Admin panel ─────────────────────────────────────────────────────────────
# Contraseña básica para el panel /admin
ADMIN_PASSWORD=admin123

# ─── Estudio (datos de contacto para el bot) ─────────────────────────────────
ESTUDIO_NOMBRE=Estudio Jurídico Lafranconi
ESTUDIO_DIRECCION=25 de Mayo 123, Oberá, Misiones
ESTUDIO_TELEFONO=+54 3755 000000
ESTUDIO_HORARIO=Lunes a Viernes de 8:00 a 12:00 y 16:00 a 20:00
ESTUDIO_EMAIL=lafranconi@estudio.com.ar
